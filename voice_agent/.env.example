# ── Gemini / Vertex AI ───────────────────────────────────────────────────────
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=models/gemini-3.1-flash-live-preview

# Optional: Use Vertex AI instead of Gemini API (for enterprise deployments)
USE_VERTEX_AI=false
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=path/to/your-service-account-key.json

# ── LiveKit (optional — alternative to Exotel for browser-based calls) ───────
USE_LIVEKIT=false
LIVEKIT_URL=wss://your-livekit-server.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# ── Exotel ────────────────────────────────────────────────────────────────────
# Get credentials from https://my.exotel.com/settings/site#api-settings
EXOTEL_API_KEY=your-exotel-api-key
EXOTEL_API_TOKEN=your-exotel-api-token
EXOTEL_SID=your-exotel-sid
EXOTEL_CALLER_ID=your-exotel-phone-number
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_APP_ID=your-app-id

# ── MongoDB (shared CRM — insights + lead_info) ──────────────────────────────
# MongoDB connection string for storing call insights and lead information
MONGODB_URI=mongodb://localhost:27017/voice-campaign-insights
# Or use MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/dbname

# ── Neon Postgres (campaigns, leads, credits) ────────────────────────────────
# PostgreSQL connection string for campaigns, contacts, and credit ledger
# Get from https://neon.tech or use local: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
# Public URL for webhooks (use ngrok for local dev: https://your-subdomain.ngrok-free.app)
PUBLIC_URL=https://your-domain.com

# ── Agent persona ─────────────────────────────────────────────────────────────
# Customize your AI agent's identity and voice
AGENT_NAME=Riya
COMPANY_NAME=YourCompany
PRODUCT_NAME=YourProduct
# Language code: en-IN (English-India), hi-IN (Hindi-India), en-US, etc.
AGENT_LANGUAGE=hi-IN
# Voice options: Zephyr, Puck, Charon, Kore, Fenrir, Aoede
# See: https://cloud.google.com/text-to-speech/docs/voices
GEMINI_VOICE=Zephyr
# Speaking rate: 0.25 (very slow) → 1.0 (normal) → 2.0 (fast)
GEMINI_SPEAKING_RATE=0.9

# ── Tenant / Client ID ────────────────────────────────────────────────────────
# Unique identifier for this client/tenant deployment
CLIENT_ID=default

# ── Business details ──────────────────────────────────────────────────────────
# What your business does (used in the agent's intro and pitch)
BUSINESS_TYPE=new cars ki sales aur car insurance
OPERATING_CITY=Gurgaon
INDUSTRY_EXPERIENCE=7 saal
SALES_MANAGER_NAME=Manager
# Optional: legal name, contact email, product restrictions
# COMPANY_LEGAL_NAME=
# COMPANY_EMAIL=support@yourcompany.com
# PRODUCT_RESTRICTIONS=

# Opening question after intro — what the agent asks to start the conversation
OPENING_QUESTION=Kya aap {BUSINESS_TYPE} ke baare mein soch rahe hain?

# Qualify questions — one per line, asked one at a time during the call
QUALIFY_QUESTIONS=Kaunsa option dekh rahe hain?\nBudget range kya hai?\nDelivery kahan chahiye?\nKitne time mein lena chahte hain?

# Pitch lines — 1-2 lines shown as bullet points when pitching your product
PITCH_LINES=Hum {OPERATING_CITY} mein hain, pan-India deliver karte hain — {INDUSTRY_EXPERIENCE} se trusted naam hai.\nNew purchase ke saath best deals bhi milti hain — sab ek jagah.

# Full business context override — if set, replaces the auto-generated paragraph entirely
# BUSINESS_CONTEXT=
